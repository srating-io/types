{
  "name": "@srating-io/types",
  "private": false,
  "version": "1.0.5",
  "description": "srating.io shared TypeScript types for GUI and API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "prebuild": "node scripts/generate-exports.js",
    "build": "npm run clean && tsc && echo 'export {};' > dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/srating-io/types.git"
  },
  "keywords": [],
  "author": "Evan Smalley",
  "bugs": {
    "url": "https://github.com/srating-io/types/issues"
  },
  "homepage": "https://github.com/srating-io/types#readme"
}
